# 从 Supabase Dashboard > Settings > API 获取
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# 服务端校验手机号用（仅服务器，勿暴露给前端）
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# 可选：本地/预发测试账号（生产环境勿配置）。与 /api/verify 中队伍 id + 手机号一致时直接通过
# VERIFY_TEST_TEAM_ID=1
# VERIFY_TEST_PHONE=13800138000

# 可选：备用登录号码（默认 4008517517）。任意已存在队伍 + 该号码可通过 /api/verify；设为空字符串可关闭
# VERIFY_UNIVERSAL_PHONE=4008517517
